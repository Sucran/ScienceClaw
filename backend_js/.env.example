# Server
PORT=12001
ENVIRONMENT=local

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27014
MONGODB_DB=ai_agent
MONGODB_USER=
MONGODB_PASSWORD=

# Session
SESSION_COOKIE=zdtc-agent-session
SESSION_MAX_AGE=604800

# Auth
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# LLM Model
DS_MODEL=deepseek-chat
DS_API_KEY=
DS_URL=https://api.deepseek.com/v1

# Workspace
WORKSPACE_DIR=/home/scienceclaw
TOOLS_DIR=/app/Tools
BUILTIN_SKILLS_DIR=/app/builtin_skills
EXTERNAL_SKILLS_DIR=/app/Skills

# Sandbox
SANDBOX_REST_URL=http://localhost:18080

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
